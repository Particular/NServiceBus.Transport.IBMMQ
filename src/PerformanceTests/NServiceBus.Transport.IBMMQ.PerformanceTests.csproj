<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\NServiceBusTests.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="IBMMQDotnetClient" Version="9.4.5" />
    <PackageReference Include="NServiceBus.PerformanceTests.Sources" Version="1.0.0-alpha.1" />
    <PackageReference Include="System.CommandLine" Version="2.0.5" />
    <PackageReference Include="System.IO.Hashing" Version="10.0.5" />
  </ItemGroup>

  <!-- Source package Program.cs uses removed CommandLineConfiguration; override with local copy -->
  <ItemGroup>
    <Compile Remove="$(NuGetPackageRoot)nservicebus.performancetests.sources/**/NSB.PerformanceTests/Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Transport\NServiceBus.Transport.IBMMQ.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Testing\ShortenedTopicNaming.cs" />
    <Compile Include="..\Testing\TestConnectionDetails.cs" />
  </ItemGroup>

</Project>
